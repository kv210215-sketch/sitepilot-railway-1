# =============================================================================
# SitePilot Frontend — Railway Environment Variables
# In Railway: set these in the service Variables tab
# IMPORTANT: NEXT_PUBLIC_* vars must be set BEFORE the first build
# =============================================================================

# ── API ───────────────────────────────────────────────────────────────────────
# Your Railway backend service URL (no trailing slash)
# Get this after deploying the backend service
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=SitePilot
