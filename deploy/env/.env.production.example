# =============================================================================
# SitePilot — Production Environment
# Файл: sitepilot-deploy/env/.env.production
# ⚠️  НІКОЛИ не комітити цей файл у Git!
# =============================================================================

# App
NODE_ENV=production
PORT=3001
APP_URL=https://api.solomiya-energy.com
FRONTEND_URL=https://app.solomiya-energy.com
API_PREFIX=api/v1
CORS_ORIGINS=https://app.solomiya-energy.com

# Database (postgres container — через docker network)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sitepilot_prod
DB_USER=sitepilot_prod
DB_PASS=CHANGE_ME_STRONG_DB_PASSWORD_32CHARS
DB_SSL=false
DB_SYNC=false
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=CHANGE_ME_STRONG_REDIS_PASSWORD

# JWT — обов'язково замінити на crypto.randomBytes(64).toString('hex')
JWT_SECRET=CHANGE_ME_PROD_JWT_SECRET_MIN_64_CHARS_RANDOM
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_PROD_REFRESH_SECRET_MIN_64_CHARS_RANDOM
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
