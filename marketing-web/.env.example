# Backend public read API (no trailing slash)
NEXT_PUBLIC_PUBLIC_API_URL=http://localhost:3001

# Marketing site origin for canonical / sitemap / robots (no trailing slash)
# Leave unset locally to derive from request Host header.
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3002

# Staging: block indexing site-wide
# MARKETING_FORCE_NOINDEX=true

# Optional SEO defaults (no production host hardcoding required)
# NEXT_PUBLIC_SITE_NAME=
# NEXT_PUBLIC_DEFAULT_OG_IMAGE=/og-image.jpg
# NEXT_PUBLIC_TWITTER_SITE=
# NEXT_PUBLIC_DEFAULT_LOCALE=uk_UA

# Google Analytics 4 — set to your GA4 Measurement ID (e.g. G-XXXXXXXXXX) to
# enable analytics + the generate_lead conversion event. Leave unset to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console — verification token (Settings → Ownership → HTML tag).
# Renders <meta name="google-site-verification" ...>. Leave unset to disable.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
