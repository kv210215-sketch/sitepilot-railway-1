# =============================================================================
# Backend E2E tests — LOCAL test DB only. Never point at staging/production.
# Defaults are also baked into test/setup-env.ts; override here or via real env.
# =============================================================================
NODE_ENV=test
# A disposable local Postgres (e.g. `docker compose up -d db` then create sitepilot_test,
# or a throwaway container on another port). NEVER the staging DATABASE_PUBLIC_URL.
# Keep host as `localhost`: data-source.ts enables SSL for any non-localhost host,
# which a plain local Postgres rejects.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sitepilot_test
DB_SSL=false
DB_SYNC=false
API_PREFIX=api/v1
JWT_SECRET=e2e_test_jwt_secret_change_me
JWT_REFRESH_SECRET=e2e_test_refresh_secret_change_me
PUBLIC_API_ENABLED=true
PUBLIC_DEFAULT_PROJECT_SLUG=solomiya-energy
THROTTLE_LIMIT=100000
