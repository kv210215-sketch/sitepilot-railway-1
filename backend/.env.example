# =============================================================================
# SitePilot Backend — Environment Variables
# Copy this file to .env and fill in your values.
# In Railway: set these in the service Variables tab.
# [REQUIRED] vars will cause the app to refuse to start if missing.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1
BCRYPT_ROUNDS=12

# CORS: comma-separated origins, or * to allow all (dev/testing only)
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Option A — single connection URL [REQUIRED if DB_HOST is not set]
# Railway Postgres plugin sets DATABASE_URL automatically.
# Generate: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Option B — individual vars [REQUIRED if DATABASE_URL is not set]
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sitepilot
DB_USER=postgres
DB_PASS=
DB_SSL=false

# DB_SYNC=true — auto-sync schema (dev only, NEVER in production)
DB_SYNC=false
DB_LOGGING=false

# ── JWT [REQUIRED] ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=15m
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── MongoDB (optional — used by movies module / future Mongoose features) ─────
MONGO_URI=

# ── Stripe billing (optional — billing features disabled if empty) ────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Tilda automation (optional) ───────────────────────────────────────────────
TILDA_EMAIL=
TILDA_PASSWORD=

# ── Admin seed (optional — super-admin user auto-created on first boot) ────────
ADMIN_EMAIL=admin@sitepilot.io
ADMIN_PASSWORD=
ADMIN_NAME=Super Admin

# ── AI (optional) ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
