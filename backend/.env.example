# =============================================================================
# SitePilot Backend — Environment Variables
# Copy this file to .env and fill in your values.
# In Railway: set these in the service Variables tab.
# Staging template (placeholders, no prod hosts): .env.staging.example
# [REQUIRED] vars will cause the app to refuse to start if missing.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1
BCRYPT_ROUNDS=12

# CORS: comma-separated origins, or * to allow all (dev/testing only)
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Option A — single connection URL [REQUIRED if DB_HOST is not set]
# Railway Postgres plugin sets DATABASE_URL automatically.
# Generate: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Option B — individual vars [REQUIRED if DATABASE_URL is not set]
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sitepilot
DB_USER=postgres
DB_PASS=
DB_SSL=false

# DB_SYNC=true — auto-sync schema (dev only, BLOCKED in production by validateEnv)
# In production always use: npm run migration:run
DB_SYNC=false
DB_LOGGING=false

# ── JWT [REQUIRED] ────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 32
# [REQUIRED] — app refuses to start without these
# In production, default dev values are explicitly blocked by validateEnv
JWT_SECRET=
JWT_EXPIRES_IN=15m
# [REQUIRED]
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── MongoDB (optional — used by movies module / future Mongoose features) ─────
MONGO_URI=

# ── Stripe billing (optional — billing features disabled if empty) ────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Public read API (marketing-web) ───────────────────────────────────────────
# PUBLIC_API_ENABLED:
#   - When explicitly "true", enables read-only public pages API.
#   - When explicitly "false", forces it off even in non-production.
#   - When unset, backend uses NODE_ENV-based heuristic (see configuration.ts).
# For local dev, leave unset or set to "true" once pages exist.
PUBLIC_API_ENABLED=
# Default public project selection. Slugs are unique only within an organization,
# so prefer the globally-unique id; or scope the slug with an org id. The bare
# slug is for single-tenant installs only.
PUBLIC_DEFAULT_PROJECT_ID=
PUBLIC_DEFAULT_ORG_ID=
PUBLIC_DEFAULT_PROJECT_SLUG=solomiya-energy
# Origin for canonical/OG URLs when a project has no domain (e.g. https://www.solomiya-energy.com).
# Leave unset to let marketing-web derive canonical from the request origin.
PUBLIC_MARKETING_ORIGIN=

# ── Lead / Telegram (planned backend module; parity with Solomiya landing) ────
# Contract:
#   - LEAD_SINK=sandbox for local/staging dry-runs (no real Telegram delivery).
#   - TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID are secrets set only in real deploys.
#   - Never paste production tokens or chat IDs into this file.
LEAD_SINK=sandbox
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Tilda automation (optional) ───────────────────────────────────────────────
TILDA_EMAIL=
TILDA_PASSWORD=

# ── Admin seed (optional — super-admin user auto-created on first boot) ────────
ADMIN_EMAIL=admin@sitepilot.io
ADMIN_PASSWORD=
ADMIN_NAME=Super Admin

# ── AI (optional) ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
