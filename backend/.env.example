# =============================================================================
# SitePilot Backend — Environment Variables
# Copy this file to .env and fill in your values.
# In Railway: set these in the service Variables tab.
# [REQUIRED] vars will cause the app to refuse to start if missing.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1
BCRYPT_ROUNDS=12

# CORS: comma-separated origins, or * to allow all (dev/testing only)
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Option A — single connection URL [REQUIRED if DB_HOST is not set]
# Railway Postgres plugin sets DATABASE_URL automatically.
# Generate: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Option B — individual vars [REQUIRED if DATABASE_URL is not set]
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sitepilot
DB_USER=postgres
DB_PASS=
DB_SSL=false

# DB_SYNC=true — auto-sync schema (dev only, BLOCKED in production by validateEnv)
# In production always use: npm run migration:run
DB_SYNC=false
DB_LOGGING=false

# ── JWT [REQUIRED] ────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 32
# [REQUIRED] — app refuses to start without these
# In production, default dev values are explicitly blocked by validateEnv
JWT_SECRET=
JWT_EXPIRES_IN=15m
# [REQUIRED]
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# Express 'trust proxy' — upstream proxy hops to trust for X-Forwarded-For.
# 1 = the single Railway edge proxy (default). Also accepts true/false or a
# subnet/preset string (e.g. loopback). Required so rate limiting tracks real
# client IPs instead of the proxy's.
TRUST_PROXY=1

# ── MongoDB (optional — used by movies module / future Mongoose features) ─────
MONGO_URI=

# ── Stripe billing (optional — billing features disabled if empty) ────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Tilda automation (optional) ───────────────────────────────────────────────
TILDA_EMAIL=
TILDA_PASSWORD=

# ── Admin seed (optional — super-admin user auto-created on first boot) ────────
ADMIN_EMAIL=admin@sitepilot.io
ADMIN_PASSWORD=
ADMIN_NAME=Super Admin

# ── Outbound mail / lead notifications (optional) ─────────────────────────────
# When SMTP_HOST is empty, MailService logs instead of sending (dev/test safe).
# Set these to deliver real lead-notification emails to project owners.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SitePilot <no-reply@sitepilot.local>
# Optional catch-all that ALSO receives every lead notification (e.g. a shared inbox).
LEADS_NOTIFY_EMAIL=

# ── AI (optional) ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
